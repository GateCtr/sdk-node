{
  "name": "@gatectr/sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for GateCtr — One gateway. Every LLM.",
  "license": "MIT",
  "author": "GateCtr",
  "homepage": "https://gatectr.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/GateCtr/sdk-node.git"
  },
  "bugs": {
    "url": "https://github.com/GateCtr/sdk-node/issues"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "gateway",
    "ai",
    "sdk"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/postbuild.mjs",
    "clean": "node scripts/clean.mjs",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "msw": "^2.12.11",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
